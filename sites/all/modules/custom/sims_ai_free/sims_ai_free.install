<?php

/**
 * @file
 * Install, update and uninstall functions for SIMS AI Free module.
 */

/**
 * Implements hook_schema().
 */
function sims_ai_free_schema() {
$schema = array();

// Conversations table
$schema['sims_ai_conversations'] = array(
'description' => 'AI chatbot conversations',
'fields' => array(
    'conversation_id' => array(
    'type' => 'serial',
    'not null' => TRUE,
    'description' => 'Conversation ID',
    ),
    'uid' => array(
    'type' => 'int',
    'not null' => TRUE,
    'description' => 'User ID',
    ),
    'startup_id' => array(
    'type' => 'int',
    'description' => 'Related startup node ID',
    ),
    'created' => array(
    'type' => 'int',
    'not null' => TRUE,
    'description' => 'Created timestamp',
    ),
    'updated' => array(
    'type' => 'int',
    'not null' => TRUE,
    'description' => 'Updated timestamp',
    ),
),
'primary key' => array('conversation_id'),
'indexes' => array(
    'uid' => array('uid'),
    'startup_id' => array('startup_id'),
    'updated' => array('updated'),
),
);

// Messages table
$schema['sims_ai_messages'] = array(
'description' => 'Chat messages',
'fields' => array(
    'message_id' => array(
    'type' => 'serial',
    'not null' => TRUE,
    'description' => 'Message ID',
    ),
    'conversation_id' => array(
    'type' => 'int',
    'not null' => TRUE,
    'description' => 'Conversation ID',
