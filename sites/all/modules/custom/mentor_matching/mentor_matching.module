<?php
/**
 * @file
 * Smart Mentor Matching Module for SIMS
 * Main module file - contains only hooks
 */

/**
 * Implements hook_menu()
 */
function mentor_matching_menu() {
$items = array();

$items['mentor-matching/%node'] = array(
  'title' => 'Find Matching Mentors',
  'page callback' => 'mentor_matching_results_page',
  'page arguments' => array(1),
  'access arguments' => array('administer content'),
  'file' => 'mentor_matching.pages.inc',
  'type' => MENU_CALLBACK,
);

$items['mentor-matching/%node/auto-assign/%'] = array(
  'title' => 'Auto Assign Mentor',
  'page callback' => 'mentor_matching_auto_assign',
  'page arguments' => array(1, 3),
  'access arguments' => array('administer content'),
  'file' => 'mentor_matching.pages.inc',
  'type' => MENU_CALLBACK,
);

$items['admin/reports/mentor-matching-history'] = array(
  'title' => 'Mentor Matching History',
  'description' => 'View history of all mentor assignments',
  'page callback' => 'mentor_matching_history_page',
  'access arguments' => array('administer content'),
  'file' => 'mentor_matching.pages.inc',
  'type' => MENU_NORMAL_ITEM,
);

return $items;
}

/**
 * Implements hook_node_view()
 */
function mentor_matching_node_view($node, $view_mode, $langcode) {
if ($node->type == 'startup_idea' && $view_mode == 'full') {
  if (user_access('administer content')) {
    $node->content['mentor_matching_button'] = array(
      '#markup' => '<div class="mentor-matching-section">
        <h3>🎯 Smart Mentor Matching</h3>
        <p>Find the best mentor for this startup based on industry expertise.</p>
        <a href="/drupal7/?q=mentor-matching/' . $node->nid . '" 
            class="button mentor-match-btn">
            🔍 Find Best Mentors
        </a>
      </div>',
      '#weight' => 100,
    );
    
    drupal_add_css(drupal_get_path('module', 'mentor_matching') . '/mentor_matching.css');
  }
}
}

/**
 * Implements hook_mail()
 */
function mentor_matching_mail($key, &$message, $params) {
switch ($key) {
  case 'mentor_assigned':
    $message['subject'] = $params['subject'];
    $message['body'][] = $params['body'];
    break;
}
}

/**
 * Implements hook_help()
 */
function mentor_matching_help($path, $arg) {
switch ($path) {
  case 'admin/help#mentor_matching':
    return '<p>' . t('Smart Mentor Matching helps admins find the best mentor for each startup based on industry expertise and availability.') . '</p>';
}
}