<?php

/**
 * Implements hook_menu().
 */
function ai_startup_menu() {
  $items = array();

  // Chatbot page
  $items['ai-startup/companion'] = array(
    'title' => 'AI Startup Companion',
    'page callback' => 'ai_startup_companion_page',
    'access arguments' => array('access content'),
    'type' => MENU_NORMAL_ITEM,
  );

  // Test HF API key page
  $items['ai-startup/test-api'] = array(
    'title' => 'Test Hugging Face API Key',
    'page callback' => 'ai_startup_test_api',
    'access arguments' => array('access content'),
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Page callback: display HF API key for testing.
 */
function ai_startup_test_api() {
  $api_key = variable_get('ai_startup_hf_api_key', '');
  drupal_set_message('HF API Key: ' . $api_key);
  return 'Check above messages for the API key.';
}

/**
 * Chatbot page for startup questions.
 */
function ai_startup_companion_page() {
  $output = '<h2>Startup Companion Bot 🤖</h2>';
  $output .= '<form method="post">';
  $output .= '<label>Ask your Startup Companion:</label><br>';
  $output .= '<input type="text" name="ai_question" style="width: 60%;" required>';
  $output .= '<input type="submit" value="Ask" style="margin-left: 10px;">';
  $output .= '</form>';

  if (!empty($_POST['ai_question'])) {
    $question = $_POST['ai_question'];
    $api_key = variable_get('ai_startup_hf_api_key', '');
    $model = 'mistralai/Mistral-7B-Instruct-v0.2';

    $answer = ai_startup_call_hf($model, $api_key, $question);
    $output .= '<h3>Bot Answer:</h3>';
    $output .= '<div style="border:1px solid #ccc; padding:10px; max-width:70%;">' . check_plain($answer) . '</div>';
  }

  return $output;
}

/**
 * Helper function to call Hugging Face Router API for text generation.
 */
function ai_startup_call_hf($model, $api_key, $input_text) {
  $url = "https://api-inference.huggingface.co/pipeline/text-generation/$model";

  $payload = [
    'inputs' => $input_text,
    'parameters' => [
      'max_new_tokens' => 200,
      'temperature' => 0.7,
      'return_full_text' => false,
    ],
  ];

  $ch = curl_init($url);
  curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
  curl_setopt($ch, CURLOPT_HTTPHEADER, [
    "Authorization: Bearer $api_key",
    "Content-Type: application/json"
  ]);
  curl_setopt($ch, CURLOPT_POST, true);
  curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode($payload));

  $response = curl_exec($ch);
  $err = curl_error($ch);
  curl_close($ch);

  if ($err) {
    watchdog('ai_startup', 'cURL error: @error', ['@error' => $err]);
    return "API request failed: $err";
  }

  $result = json_decode($response, true);

  if (!$result || !isset($result[0]['generated_text'])) {
    watchdog('ai_startup', 'HF API returned invalid response: @resp', ['@resp' => $response]);
    return "Sorry, the AI could not generate an answer. Try again!";
  }

  return trim($result[0]['generated_text']);
}
